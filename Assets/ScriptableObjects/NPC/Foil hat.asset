  m_Name: Foil hat
  m_EditorClassIdentifier: Assembly-CSharp::NPCData
  _name: "\u0410\u0440\u0441\u0435\u043D\u0438\u0439 \u0425\u0430\u0440\u0438\u0442\u043E\u043D\u043E\u0432"
  male: 1
  infected: 0
  temperature: 36.6
  heartRate: 75
  arms: 0
  mouth: 0
  eyes: 0
  armpits: 0
  sprite: {fileID: 6451935231278058049, guid: c3cb917fd793d5f41979a97ce8837df0, type: 3}
  voiceClip: {fileID: 8300000, guid: e3915aee755bdcb44a6e6b3b344f959e, type: 3}
  entryLines:
  - text: "\u0422\u044B \u0432\u0435\u0434\u044C \u0447\u0435\u043B\u043E\u0432\u0435\u043A?"
    delay: 1
  - text: "\u0413\u043B\u0430\u0437\u0430 \u0432\u0440\u043E\u0434\u0435 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0435..."
    delay: 0.1
  dialog:
  - question: "\u0421 \u043A\u0430\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
      \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434?"
    answers:
    - text: "\u0412\u0430\u0448 \u0433\u043E\u0440\u043E\u0434 \u0441\u0442\u043E\u0438\u0442
        \u043D\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0435 \u0434\u0432\u0443\u0445
        \u0434\u0440\u0435\u0432\u043D\u0435\u0439\u0448\u0438\u0445 \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
        \u0446\u0438\u0432\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0439!"
      delay: 1.5
    - text: "\u0412\u044B \u041E\u0411\u0420\u0415\u0427\u0415\u041D\u042B..."
      delay: 1.5
    - text: "\u042F \u0440\u0430\u0441\u0441\u043A\u0430\u0436\u0443 \u043F\u043E\u0442\u043E\u043C\u043A\u0430\u0445
        \u043E \u0442\u043E\u043C, \u043A\u0430\u043A\u0438\u043C\u0438 \u0432\u044B
        \u0431\u044B\u043B\u0438. "
      delay: 0.1
  - question: "\u0411\u043E\u043B\u0435\u043B\u0438 \u043B\u0438 \u0412\u044B \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0447\u0435\u043C-\u043B\u0438\u0431\u043E?"
    answers:
    - text: "\u0412\u0441\u0435 \u0432\u0438\u0440\u0443\u0441\u044B \u0432\u044B\u0432\u0435\u0434\u0435\u043D\u044B
        \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u043E
        \u0438 \u0432\u0432\u0435\u0434\u0435\u043D\u044B \u043D\u0430\u043C. \u041C\u044B
        \u043B\u0438\u0448\u044C \u043A\u0440\u044B\u0441\u044B, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
        \u0441\u0442\u0430\u0432\u044F\u0442 \u043E\u043F\u044B\u0442\u044B!"
      delay: 0.1
  - question: "\u041A\u0430\u043A \u0412\u044B \u0432\u043E\u043E\u0431\u0449\u0435
      \u043F\u0440\u043E\u0448\u043B\u0438 \u0441\u044E\u0434\u0430 \u0447\u0435\u0440\u0435\u0437
      \u043D\u0430\u0448 \u043C\u0435\u0442\u0430\u043B\u043B\u043E\u0438\u0441\u043A\u0430\u0442\u0435\u043B\u044C?"
    answers:
    - text: "\u0422\u0438\u0448\u0435! \u0412\u0430\u0448 \u043E\u0445\u0440\u0430\u043D\u043D\u0438\u043A
        \u043E\u0434\u0438\u043D \u0438\u0437 \u043D\u0438\u0445."
      delay: 1
    - text: "\u042F \u0442\u043E\u0447\u043D\u043E \u043D\u0435 \u043C\u043E\u0433\u0443
        \u044D\u0442\u043E\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
        \u043D\u043E \u043E\u043D \u043E\u0447\u0435\u043D\u044C \u0445\u043E\u0442\u0435\u043B
        \u0441\u043D\u044F\u0442\u044C \u0441 \u043C\u0435\u043D\u044F \u0448\u0430\u043F\u043A\u0443."
      delay: 1.5
    - text: "\u0423\u0432\u0435\u0440\u0435\u043D, \u0435\u0441\u043B\u0438 \u043E\u043D
        \u0438 \u043D\u0435 \u0442\u043E\u0442, \u0442\u043E \u0442\u043E\u0447\u043D\u043E
        \u0432 \u0441\u0433\u043E\u0432\u043E\u0440\u0435 \u0441 \u043D\u0438\u043C\u0438.
        \u0410\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u0435\u0435 \u0441 \u043D\u0438\u043C!"
      delay: 0.1
  passingLines:
  - text: "\u041E\u043D\u0438 \u043F\u043E\u0432\u0441\u044E\u0434\u0443!"
    delay: 0.1
  stayingLines:
  - text: "\u0421\u0442\u043E\u0439! \u0422\u044B \u0442\u043E\u0436\u0435 \u043E\u0434\u0438\u043D
      \u0438\u0437 \u043D\u0438\u0445?!"
    delay: 2
  - text: "\u0412\u044B \u043D\u0435 \u0441\u043E\u0431\u044A\u0435\u0442\u0435 \u0441
      \u043C\u0435\u043D\u044F \u0449\u0438\u0442. \u041D\u0418 \u0417\u0410 \u0427\u0422\u041E!"
    delay: 0.1
