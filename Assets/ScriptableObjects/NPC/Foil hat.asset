  armpits: 0
  sprite: {fileID: 6451935231278058049, guid: c3cb917fd793d5f41979a97ce8837df0, type: 3}
  voiceClip: {fileID: 8300000, guid: e3915aee755bdcb44a6e6b3b344f959e, type: 3}
  dialog:
  - question: "\u0421 \u043A\u0430\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
      \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434?"
    answer: "\u0422\u044B \u043D\u0435 \u0437\u043D\u0430\u043B? \u0413\u043E\u0440\u043E\u0434
      \u043B\u0438\u0448\u044C \u043F\u0440\u0438\u043A\u0440\u044B\u0442\u0438\u0435.
      \u041F\u0440\u0438\u0448\u0435\u043B\u044C\u0446\u044B \u0443\u0436\u0435 \u0434\u0430\u0432\u043D\u043E
      \u043D\u0430\u0441\u0435\u043B\u044F\u044E\u0442 \u043F\u043B\u0430\u043D\u0435\u0442\u0443.
      \u041D\u0435 \u0434\u0430\u0439 \u0441\u0435\u0431\u044F \u043E\u0431\u043C\u0430\u043D\u0443\u0442\u044C!"
  - question: "\u0411\u043E\u043B\u0435\u043B\u0438 \u043B\u0438 \u0412\u044B \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0447\u0435\u043C-\u043B\u0438\u0431\u043E?"
    answer: "\u0412\u0441\u0435 \u0432\u0438\u0440\u0443\u0441\u044B \u0432\u044B\u0432\u0435\u0434\u0435\u043D\u044B
      \u0438\u0441\u043A\u0443\u0441\u0442\u0432\u0435\u043D\u043D\u043E \u0438 \u0432\u0432\u0435\u0434\u0435\u043D\u044B
      \u043D\u0430\u043C. \u041C\u044B \u043B\u0438\u0448\u044C \u043A\u0440\u044B\u0441\u044B,
      \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0442\u0430\u0432\u044F\u0442
      \u043E\u043F\u044B\u0442\u044B!"
  - question: "\u041A\u0430\u043A \u0412\u044B \u0432\u043E\u043E\u0431\u0449\u0435
      \u043F\u0440\u043E\u0448\u043B\u0438 \u0441\u044E\u0434\u0430 \u0447\u0435\u0440\u0435\u0437
      \u043D\u0430\u0448 \u043C\u0435\u0442\u0430\u043B\u043B\u043E\u0438\u0441\u043A\u0430\u0442\u0435\u043B\u044C?"
    answer: "\u0422\u0438\u0448\u0435! \u0432\u0430\u0448 \u043E\u0445\u0440\u0430\u043D\u043D\u0438\u043A
      \u0438\u0437 \u044D\u0442\u0438\u0445. \u042F \u0442\u043E\u0447\u043D\u043E
      \u044D\u0442\u043E \u043D\u0435 \u0437\u043D\u0430\u044E, \u043D\u043E \u043E\u043D
      \u043E\u0447\u0435\u043D\u044C \u0445\u043E\u0442\u0435\u043B \u0441\u043D\u044F\u0442\u044C
      \u0441 \u043C\u0435\u043D\u044F \u0448\u0430\u043F\u043A\u0443. \u041D\u0430\u0432\u0435\u0440\u043D\u044F\u043A\u0430
      \u0434\u043B\u044F \u0442\u043E\u0433\u043E, \u0447\u0442\u043E\u0431\u044B
      \u043F\u0440\u043E\u043D\u0438\u043A\u043D\u0443\u0442\u044C \u0432 \u043C\u043E\u0439
      \u043C\u043E\u0437\u0433. \u0422\u044B \u0441 \u043D\u0438\u043C \u043F\u043E\u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u0435\u0435,
      \u0432 \u0442\u0432\u043E\u0439 \u043C\u043E\u0437\u0433 \u043C\u043E\u0436\u0435\u0442
      \u0438 \u043D\u0435 \u0437\u0430\u0447\u0435\u043C \u043F\u0440\u043E\u043D\u0438\u043A\u0430\u0442\u044C,
      \u043D\u043E \u0434\u0440\u0443\u0433\u0438\u0435 \u043B\u044E\u0434\u0438
      \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C \u0432 \u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438."
  passingPhrase: "\u0418\u043D\u043E\u043F\u043B\u0430\u043D\u0435\u0442\u044F\u043D\u0435
    \u043F\u043E\u0432\u0441\u044E\u0434\u0443!"
  stayingPhrase: "\u041D\u0435 \u0441\u043C\u043E\u0442\u0440\u0438 \u043C\u043D\u0435
    \u0432 \u0433\u043B\u0430\u0437\u0430. \u041E\u043D\u0438 \u0443\u0437\u043D\u0430\u044E\u0442
    \u0447\u0442\u043E \u0442\u044B \u0437\u0434\u0435\u0441\u044C"
