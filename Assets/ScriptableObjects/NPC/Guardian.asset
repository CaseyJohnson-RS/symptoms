--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c7bebad63d5507046b60f30202f7b5e4, type: 3}
  m_Name: Guardian
  m_EditorClassIdentifier: Assembly-CSharp::NPCData
  _name: "\u0420\u043E\u0431\u0435\u0440\u0442 \u0421\u043E\u0431\u043E\u043B\u0435\u0432"
  male: 1
  infected: 0
  temperature: 36
  heartRate: 120
  arms: 0
  mouth: 0
  eyes: 0
  armpits: 0
  sprite: {fileID: -5620387682234655531, guid: 077792d7e51294d4db0a968a1a5e4e75, type: 3}
  voiceClip: {fileID: 8300000, guid: e3915aee755bdcb44a6e6b3b344f959e, type: 3}
  entryLines:
  - text: "\u0417\u043D\u0430\u0447\u0438\u0442 \u0442\u044B \u043D\u043E\u0432\u0435\u043D\u044C\u043A\u0438\u0439?"
    delay: 1
  - text: "\u041C\u0435\u043D\u044F \u043F\u0440\u0438\u0441\u0442\u0430\u0432\u0438\u043B\u0438
      \u043A \u0442\u0435\u0431\u0435 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C
      \u043A\u0430\u043A \u0438 \u0447\u0442\u043E \u0442\u0443\u0442 \u0443\u0441\u0442\u0440\u043E\u0435\u043D\u043E."
    delay: 1
  - text: "\u041C\u043D\u0435 \u044D\u0442\u043E \u0441\u0430\u043C\u043E\u043C\u0443
      \u043D\u0430\u0444\u0438\u0433 \u043D\u0435 \u043D\u0430\u0434\u043E. \u0415\u0441\u043B\u0438
      \u0443 \u0442\u0435\u0431\u044F \u043D\u0435\u0442 \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432,
      \u0442\u043E \u043D\u0430\u0436\u043C\u0438 \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443
      \"\u041F\u0440\u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C\"."
    delay: 1
  - text: "\u0415\u0441\u043B\u0438 \u0435\u0441\u0442\u044C \u0432\u043E\u043F\u0440\u043E\u0441\u044B.
      *\u0432\u0437\u0434\u043E\u0445*"
    delay: 1
  - text: "\u041D\u0430\u0447\u043D\u0435\u043C \u0441 \u043F\u0440\u043E\u0441\u0442\u043E\u0433\u043E.
      \u0411\u0430\u043B\u0430\u043A\u0430\u0435\u0448\u044C \u043F\u043E \u043D\u0430\u0448\u0435\u043C\u0443?"
    delay: 1
  dialog:
  - question: "\u041E\u0431\u044A\u044F\u0441\u043D\u0438 \u0447\u0442\u043E \u0442\u0443\u0442
      \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442."
    answers:
    - text: "\u0417\u043D\u0430\u0447\u0438\u0442 \u043E\u0431\u044A\u044F\u0441\u043D\u044E
        \u043E\u0441\u043D\u043E\u0432\u044B, \u0430 \u0434\u0430\u043B\u044C\u0448\u0435
        \u0441\u0430\u043C."
      delay: 1
    - text: "\u041A\u0430\u043A-\u043D\u0438\u043A\u0430\u043A \u044D\u0442\u043E
        \u0442\u0435\u0431\u044F \u0432\u0437\u044F\u043B\u0438 \u043D\u0430 \u044D\u0442\u0443
        \u0440\u0430\u0431\u043E\u0442\u0443. \u042F \u0432\u0441\u0435\u0433\u043E
        \u043B\u0438\u0448\u044C \u043E\u0445\u0440\u0430\u043D\u043D\u0438\u043A
        \u0438 \u0432\u0441\u0435\u0433\u043E \u043D\u0435 \u0437\u043D\u0430\u044E."
      delay: 1.5
    - text: "\u0422\u0443\u0442 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C\u043D\u043E-\u043F\u0440\u043E\u043F\u0443\u0441\u043A\u043D\u043E\u0439
        \u043F\u0443\u043D\u043A\u0442. \u042F - \u043E\u0445\u0440\u0430\u043D\u044F\u044E
        \u0433\u0440\u0430\u043D\u0438\u0446\u0443. \u0415\u0441\u043B\u0438 \u043A\u0430\u043A\u0438\u0435
        \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B - \u0437\u043E\u0432\u0438
        \u043C\u0435\u043D\u044F."
      delay: 1.5
    - text: "\u0422\u044B - \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0435\u0440.
        \u041F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0448\u044C \u0440\u0435\u0448\u0435\u043D\u0438\u044F
        \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u0442\u044C \u0438\u043B\u0438
        \u043D\u0435\u0442 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0438\u0445
        \u0432 \u0433\u043E\u0440\u043E\u0434."
      delay: 1.5
    - text: "\u0422\u044B - \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0435\u0440.
        \u041F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0448\u044C \u0440\u0435\u0448\u0435\u043D\u0438\u044F
        \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u0442\u044C \u0438\u043B\u0438
        \u043D\u0435\u0442 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0438\u0445
        \u0432 \u0433\u043E\u0440\u043E\u0434."
      delay: 1.5
    - text: "\u0427\u0442\u043E-\u0442\u043E \u0435\u0449\u0435?"
      delay: 0.1
  - question: "\u041A\u0430\u043A \u043C\u043D\u0435 \u0432\u044B\u044F\u0432\u0438\u0442\u044C
      \u0437\u0430\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0445?"
    answers:
    - text: "\u042F-\u0442\u043E \u043E\u0442\u043A\u0443\u0434\u0430 \u0437\u043D\u0430\u044E? "
      delay: 1
    - text: "\u0421\u043C\u043E\u0442\u0440\u0438 \u043A\u0442\u043E \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
        \u0441\u0442\u0440\u0430\u043D\u043D\u043E. \u0410\u0445, \u0434\u0430."
      delay: 1
    - text: "\u0422\u0435\u0431\u0435 \u0434\u043E\u043B\u0436\u043D\u044B \u0431\u044B\u043B\u0438
        \u0432\u044B\u0434\u0430\u0442\u044C \u0444\u043E\u0442\u043E\u0430\u043F\u043F\u0430\u0440\u0430\u0442.
        \u041E\u043D \u0432\u0440\u043E\u0434\u0435 \u043A\u0430\u043A\u043E\u0439-\u0442\u043E
        \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u044B\u0439."
      delay: 1
    - text: "\u0422\u043E \u043B\u0438 \u0443\u0447\u0435\u043D\u044B\u0435 \u0435\u0433\u043E
        \u043F\u043E\u0434\u043A\u0440\u0443\u0442\u0438\u043B\u0438, \u0442\u043E
        \u043B\u0438 \u043A\u0442\u043E-\u0442\u043E \u0435\u0433\u043E \u0443\u0440\u043E\u043D\u0438\u043B
        \u0432 \u0447\u0430\u043D \u0441\u043E \u0441\u043F\u0438\u0440\u0442\u043E\u043C.
        \u041A\u043E\u0440\u043E\u0447\u0435, \u043E\u043D \u0442\u0438\u043F\u0430
        \u043B\u0443\u0447\u0448\u0435 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u0435\u0442
        \u0432\u0441\u0435 \u0441\u0438\u043C\u043F\u0442\u043E\u043C\u044B. "
      delay: 2
    - text: "\u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u043D\u0438\u043C \u0442\u0435\u0431\u0435
        \u0434\u043E\u043B\u0436\u043D\u044B \u0431\u044B\u043B\u0438 \u0432\u044B\u0434\u0430\u0442\u044C
        \u0438 \u0444\u043E\u0442\u043E\u043A\u0430\u0440\u0442\u043E\u0447\u043A\u0438."
      delay: 1
    - text: "\u0423\u0447\u0442\u0438, \u0447\u0442\u043E \u0438\u0445 \u0432\u044B\u0434\u0430\u044E\u0442
        \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0435
        \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E. \u041C\u043E\u0436\u0435\u0448\u044C
        \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u0442\u044C \u0441\u0432\u043E\u0438,
        \u0435\u0441\u043B\u0438 \u0435\u0441\u0442\u044C."
      delay: 1
    - text: "\u0424\u043E\u0442\u043E\u0430\u043F\u043F\u0430\u0440\u0430\u0442 \u0434\u043E\u043B\u0436\u0435\u043D
        \u0445\u0440\u0430\u043D\u0438\u0442\u044C\u0441\u044F \u0432 \u044F\u0449\u0438\u043A\u0435,
        \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
        \u0437\u0430\u043F\u0438\u0440\u0430\u0435\u0442\u0441\u044F."
      delay: 1
    - text: "\u0422\u0435\u0445\u043D\u0438\u043A\u0430 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438."
      delay: 1
    - text: "\u0412\u0441\u0435 \u0441\u0434\u0435\u043B\u0430\u043D\u043D\u044B\u0439
        \u0442\u043E\u0431\u043E\u0439 \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438
        \u0445\u0440\u0430\u043D\u044F\u0442\u0441\u044F \u0432 \u0434\u0435\u043B\u0435
        \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0433\u043E."
      delay: 1.5
    - text: "\u041F\u0430\u043F\u043A\u0430 \u043B\u0435\u0436\u0438\u0442 \u043D\u0430
        \u0441\u0442\u043E\u043B\u0435, \u043F\u043E\u0434\u0430\u043B\u044C\u0448\u0435
        \u043E\u0442 \u0444\u043E\u0442\u043E\u0430\u043F\u043F\u0430\u0440\u0430\u0442\u0430."
      delay: 1
    - text: "\u0422\u0435\u0445\u043D\u0438\u043A\u0430 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438."
      delay: 1
  - question: "\u0421\u043A\u043E\u043B\u044C\u043A\u043E \u0447\u0430\u0441\u043E\u0432
      \u0440\u0430\u0431\u043E\u0447\u0438\u0439 \u0434\u0435\u043D\u044C?"
    answers:
    - text: "\u0422\u044B \u043D\u0435 \u0447\u0438\u0442\u0430\u043B \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B,
        \u043A\u043E\u0433\u0434\u0430 \u043F\u043E\u0434\u043F\u0438\u0441\u044B\u0432\u0430\u043B?"
      delay: 1
    - text: "\u041C\u044B \u0437\u0434\u0435\u0441\u044C \u0434\u043E \u0442\u0435\u0445
        \u043F\u043E\u0440, \u043F\u043E\u043A\u0430 \u043D\u0435 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u0441\u044F
        \u043F\u043E\u0442\u043E\u043A \u0436\u0435\u043B\u0430\u044E\u0449\u0438\u0445
        \u043F\u043E\u043F\u0430\u0441\u0442\u044C \u043D\u0430 \u0442\u0443 \u0441\u0442\u043E\u0440\u043E\u043D\u0443
        \u0431\u0430\u0440\u0440\u0438\u043A\u0430\u0434."
      delay: 1
    - text: "\u0421\u0435\u0433\u043E\u0434\u043D\u044F \u043E\u0447\u0435\u0440\u0435\u0434\u044C
        \u043D\u0435 \u0431\u043E\u043B\u044C\u0448\u0430\u044F. \u041D\u0435 \u0431\u043E\u043B\u044C\u0448\u0435
        10 \u0447\u0435\u043B\u043E\u0432\u0435\u043A."
      delay: 0.1
  - question: "\u041A\u0430\u043A\u0430\u044F \u043A\u043D\u043E\u043F\u043A\u0430
      \u0432\u044B\u0434\u0430\u0435\u0442 \u043F\u043E\u0431\u0435\u0434\u0443?"
    answers:
    - text: "\u0422\u044B \u0441\u0442\u0443\u043A\u043D\u0443\u0442\u044B\u0439?"
      delay: 1
    - text: "\u041A\u043D\u043E\u043F\u043A\u0430 \"\u041E\u0442\u043A\u0430\u0437\u0430\u0442\u044C\"
        \u043D\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u043C\u0443
        \u043F\u0440\u043E\u0439\u0442\u0438 \u0432 \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u043D\u044B\u0439
        \u043F\u0443\u043D\u043A\u0442."
      delay: 1
    - text: "\u041A\u043D\u043E\u043F\u043A\u0430 \"\u041F\u0440\u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C\"
        \u043D\u0430\u043E\u0431\u043E\u0440\u043E\u0442 \u0434\u0430\u0441\u0442
        \u0435\u043C\u0443 \u043F\u0440\u043E\u0439\u0442\u0438 \u0432 \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u043D\u044B\u0439
        \u043F\u0443\u043D\u043A\u0442 ."
      delay: 1
    - text: "\u041A\u043D\u043E\u043F\u043A\u0430 \"\u041E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C\"
        \u041E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u0448\u043A\u0430\u0444\u0447\u0438\u043A
        \u0441 \u0444\u043E\u0442\u043E\u0430\u043F\u043F\u0430\u0440\u0430\u0442\u043E\u043C."
      delay: 1
  - question: "\u0427\u0442\u043E \u0431\u0443\u0434\u0435\u0442 \u0435\u0441\u043B\u0438
      \u044F \u043F\u0440\u043E\u043F\u0443\u0449\u0443 \u0437\u0430\u0440\u0430\u0436\u0435\u043D\u043D\u043E\u0433\u043E?"
    answers:
    - text: "\u0423\u0432\u043E\u043B\u0438\u043C... \u0420\u0430\u0441\u0441\u0442\u0440\u0435\u043B\u044F\u0435\u043C...
        \u041F\u0443\u0431\u043B\u0438\u0447\u043D\u043E \u043E\u0433\u043B\u0430\u0441\u0438\u043C
        \u0442\u0432\u043E\u0439 \u043F\u0440\u043E\u043A\u043E\u043B... \u041F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u0435\u043C
        \u0441\u043C\u0435\u044F\u0442\u044C\u0441\u044F \u043D\u0430\u0434 \u0442\u0432\u043E\u0438\u043C\u0438
        \u0448\u0443\u0442\u043A\u0430\u043C\u0438..."
      delay: 2
    - text: "\u041D\u043E \u043F\u043E\u043A\u0430 \u0442\u0435\u0431\u0435 \u043D\u0435
        \u043D\u0430\u0448\u043B\u0438 \u0437\u0430\u043C\u0435\u043D\u0443 \u0442\u0435\u0431\u044F
        \u0431\u0443\u0434\u0443\u0442 \u0448\u0442\u0440\u0430\u0444\u043E\u0432\u0430\u0442\u044C
        \u0437\u0430 \u043F\u0440\u043E\u043F\u0443\u0449\u0435\u043D\u043D\u044B\u0445
        \u0437\u0430\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0445."
      delay: 1.5
    - text: "\u0412\u0441\u0435 \u0440\u0430\u0441\u0445\u043E\u0434\u044B \u043D\u0430
        \u043F\u043E\u0438\u0441\u043A, \u043F\u043E\u0438\u043C\u043A\u0443 \u0438
        \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435 \u0432 \u0432\u043E\u043B\u044C\u0435\u0440\u0435
        \u0437\u0430 \u0442\u0432\u043E\u0439 \u0441\u0447\u0435\u0442."
      delay: 1.5
    - text: "\u0417\u0430 \u043D\u0435\u043F\u0440\u043E\u043F\u0443\u0449\u0435\u043D\u043D\u044B\u0445
        \u0437\u0434\u043E\u0440\u043E\u0432\u044B\u0445 \u0442\u0435\u0431\u0435
        \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0435 \u0434\u043E\u043F\u043B\u0430\u0442\u044F\u0442
        \u043F\u0440\u0435\u043C\u0438\u044E."
      delay: 1
    - text: "\u041E\u0431\u043E\u0436\u0430\u044E \u043E\u0442\u0432\u0435\u0447\u0430\u0442\u044C
        \u043D\u0430 \u044D\u0442\u043E\u0442 \u0432\u043E\u043F\u0440\u043E\u0441."
      delay: 0.1
  - question: "\u0417\u0430\u0447\u0435\u043C \u043C\u043D\u0435 \u0434\u0435\u043D\u044C\u0433\u0438?"
    answers:
    - text: "\u0410 \u0442\u044B \u0432\u043A\u0430\u0447\u0430\u043B \u0444\u043E\u0442\u043E\u0441\u0438\u043D\u0442\u0435\u0437?"
      delay: 1
    - text: "\u0415\u0441\u043B\u0438 \u043D\u0435\u0442, \u0442\u043E \u0441\u0445\u043E\u0434\u0438
        \u0432 \u043C\u0430\u0433\u0430\u0437\u0438\u043D, \u043F\u043E\u043A\u0430
        \u0441\u043C\u0435\u043D\u0430 \u043D\u0435 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C.
        \u041A\u0443\u043F\u0438 \u0441\u0435\u0431\u0435 \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C
        \u0434\u043B\u044F \u043A\u043E\u043C\u0444\u043E\u0440\u0442\u043D\u043E\u0433\u043E
        \u0440\u0430\u0431\u043E\u0447\u0435\u0433\u043E \u0434\u043D\u044F."
      delay: 1.5
    - text: "\u0412 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u043C \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u0435
        \u0430\u0441\u0441\u043E\u0440\u0442\u0438\u043C\u0435\u043D\u0442 \u043C\u043E\u0436\u0435\u0442
        \u0438 \u043D\u0435 \u0441\u0430\u043C\u044B\u0439 \u0431\u043E\u043B\u044C\u0448\u043E\u0439,
        \u043D\u043E \u0432\u0441\u0435, \u0447\u0442\u043E \u043D\u0443\u0436\u043D\u043E
        \u0442\u0430\u043C \u0435\u0441\u0442\u044C. \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
        \u0443\u0434\u0435\u043B\u0438 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
        \u0444\u043E\u0442\u043E\u043A\u0430\u0440\u0442\u0430\u0447\u043A\u0430\u043C.
        \u042F \u043F\u0440\u043E \u044D\u0442\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435
        \u0433\u043E\u0432\u043E\u0440\u044E \u0432 \u043F\u0443\u043D\u043A\u0442\u0435
        \u043F\u0440\u043E \u0432\u044B\u044F\u0432\u043B\u0435\u043D\u0438\u0438
        \u0437\u0430\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0445."
      delay: 0.1
  passingLines:
  - text: "\u0423\u0434\u0430\u0447\u0438"
    delay: 1
  stayingLines:
  - text: "\u0421 \u0442\u0430\u043A\u0438\u043C\u0438 \u0448\u0443\u0442\u043A\u0430\u043C\u0438
      \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u043D\u043E\u0432\u0430\u044F
      \u0432\u0430\u043A\u0430\u043D\u0441\u0438\u044F."
    delay: 1
