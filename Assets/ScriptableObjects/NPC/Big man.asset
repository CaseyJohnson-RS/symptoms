  heartRate: 80
  arms: 0
  mouth: 0
  eyes: 0
  armpits: 0
  sprite: {fileID: 3795460515229049906, guid: 5746e52221132d54385483c4dd937bc4, type: 3}
  voiceClip: {fileID: 8300000, guid: e3915aee755bdcb44a6e6b3b344f959e, type: 3}
  dialog:
  - question: "\u0421 \u043A\u0430\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
      \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434?"
    answer: "\u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0443\u044E \u043F\u043E
      \u043C\u0438\u0440\u0443. \u0413\u043E\u0432\u043E\u0440\u044F\u0442 \u0443
      \u0432\u0430\u0441 \u043B\u0443\u0447\u0448\u0438\u0435 \u0445\u043E\u0442-\u0434\u043E\u0433\u0438,
      \u0438\u0445 \u044F \u043B\u044E\u0431\u043B\u044E \u0431\u043E\u043B\u044C\u0448\u0435
      \u0432\u0441\u0435\u0433\u043E.. \u041F\u043E\u043C\u0438\u043C\u043E \u0441\u0432\u043E\u0435\u0439
      \u043C\u0430\u0442\u0443\u0448\u043A\u0438, \u043A\u043E\u043D\u0435\u0447\u043D\u043E."
  - question: "\u0411\u043E\u043B\u0435\u043B\u0438 \u043B\u0438 \u0412\u044B \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0447\u0435\u043C-\u043B\u0438\u0431\u043E?"
    answer: "\u042F \u043D\u0430 \u043F\u0440\u0438\u0440\u043E\u0434\u0435 \u0447\u0430\u0441\u0442\u0435\u043D\u044C\u043A\u043E
      \u0431\u044B\u0432\u0430\u044E. \u0418\u043C\u043C\u0443\u043D\u0438\u0442\u0435\u0442
      \u0443 \u043C\u0435\u043D\u044F \u0432\u044B\u0440\u043E\u0431\u043E\u0442\u0430\u043B\u0441\u044F
      \u043A\u0440\u0435\u043F\u043A\u0438\u0439"
  - question: "\u0412\u0430\u043C \u043D\u0435 \u0436\u0430\u0440\u043A\u043E, \u0443
      \u0412\u0430\u0441 \u043B\u0438\u0446\u043E \u043A\u0440\u0430\u0441\u043D\u043E\u0435."
    answer: "\u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u044C \u0442\u0435\u043B\u0430.
      \u0423 \u043B\u044E\u0434\u0435\u0439 \u0441 \u0438\u043D\u0434\u0435\u043A\u0441\u043E\u043C
      \u043C\u0430\u0441\u0441\u044B \u0442\u0435\u043B\u0430 \u043A\u0430\u043A
      \u0443 \u043C\u0435\u043D\u044F \u0435\u0441\u0442\u044C \u043E\u0434\u0438\u043D
      \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043F\u043B\u044E\u0441: \u041C\u044B
      \u0432\u044B\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u043C \u043C\u043D\u043E\u0433\u043E
      \u0442\u0435\u043F\u043B\u0430, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
      \u043D\u0430\u043C \u0440\u0435\u0434\u043A\u043E \u0445\u043E\u043B\u043E\u0434\u043D\u043E."
  passingPhrase: "\u0410 \u0433\u0434\u0435 \u0443 \u0432\u0430\u0441 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0435
    \u043A\u0430\u0444\u0435?"
  stayingPhrase: "\u0414\u0443\u0448\u043D\u043E\u0432\u0430\u0442\u043E \u0437\u0434\u0435\u0441\u044C"
