  sprite: {fileID: -8677933844106142192, guid: 3e7ea104787f8544e8654582c7771382, type: 3}
  voiceClip: {fileID: 0}
  dialog:
  - question: "\u0421 \u043A\u0430\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
      \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434?"
    answer: "\u0417\u0434\u0435\u0441\u044C \u043C\u043E\u0438 \u0434\u0435\u0434\u0443\u0448\u043A\u0430
      \u0441 \u0431\u0430\u0431\u0443\u0448\u043A\u043E\u0439 \u0436\u0438\u0432\u0443\u0442.
      \u042F \u043A \u043D\u0438\u043C \u0432 \u0433\u043E\u0441\u0442\u0438 \u043F\u0440\u0438\u0435\u0445\u0430\u043B\u0430
      \u043F\u043E\u0432\u0438\u0434\u0430\u0442\u044C\u0441\u044F."
  - question: "\u0411\u043E\u043B\u0435\u043B\u0438 \u043B\u0438 \u0412\u044B \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0447\u0435\u043C-\u043B\u0438\u0431\u043E?"
    answer: "\u041D\u0435\u0442, \u043A\u043E\u043D\u0435\u0447\u043D\u043E. \u0427\u0442\u043E\u0431\u044B
      \u043F\u0440\u0438\u0435\u0445\u0430\u0442\u044C \u043A \u0412\u0430\u043C
      \u043D\u0430\u0434\u043E \u0431\u044B\u043B\u043E \u0441\u0434\u0430\u0442\u044C
      \u043D\u0430 \u0432\u0441\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0435
      \u0438 \u043D\u0435\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0435
      \u0431\u043E\u043B\u0435\u0437\u043D\u0438, \u0442\u0430\u043A \u0447\u0442\u043E
      \u044F \u0437\u0434\u043E\u0440\u043E\u0432\u0430 \u0441 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u043D\u0441\u0442\u044C
      101%."
  - question: "\u0412\u044B \u043D\u0435 \u043C\u0435\u0441\u0442\u043D\u0430\u044F
      \u043D\u0435 \u0442\u0430\u043A \u043B\u0438?"
    answer: "\u0414\u0430, \u044F \u043F\u0440\u0438\u0435\u0437\u0436\u0430\u044F.
      \u041A\u0440\u0430\u0441\u0438\u0432\u043E \u0443 \u0432\u0430\u0441, \u0432\u043E\u0442
      \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E \u043F\u0443\u0442\u0438
      \u0441\u044E\u0434\u0430 \u0443 \u043C\u0435\u043D\u044F \u0431\u0443\u043C\u0430\u0436\u043D\u0438\u043A
      \u0443\u043A\u0440\u0430\u043B\u0438, \u043D\u0430\u0434\u0435\u044E\u0441\u044C
      \u043C\u043E\u0438 \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0438
      \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u043F\u043E\u043C\u043E\u0433\u0443\u0442
      \u0441 \u044D\u0442\u0438\u043C."
  passingPhrase: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u0435."
  stayingPhrase: "\u041C\u043D\u0435 \u0436\u0435 \u043D\u0435 \u0445\u0432\u0430\u0442\u0438\u0442
    \u0434\u0435\u043D\u0435\u0433 \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u0434\u043E\u043C\u043E\u0439!"
