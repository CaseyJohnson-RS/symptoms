  m_Name: Angry woman
  m_EditorClassIdentifier: Assembly-CSharp::NPCData
  _name: "\u041B\u0438\u0434\u0438\u044F \u0421\u043D\u0435\u0436\u043E\u0432\u0430"
  infected: 0
  temperature: 36.8
  heartRate: 77
  arms: 0
  mouth: 0
  eyes: 0
  armpits: 0
  sprite: {fileID: 8931428327487941735, guid: c4148d33c407d29469ddb6f73028703f, type: 3}
  voiceClip: {fileID: 0}
  dialog:
  - question: "\u0421 \u043A\u0430\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
      \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434?"
    answer: "\u041D\u0435 \u0442\u0432\u043E\u0435 \u0434\u0435\u043B\u043E."
  - question: "\u0411\u043E\u043B\u0435\u043B\u0438 \u043B\u0438 \u0412\u044B \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0447\u0435\u043C-\u043B\u0438\u0431\u043E?"
    answer: "\u0421\u043A\u0443\u043A\u043E\u0439 \u043E\u0442 \u043F\u0440\u043E\u0441\u0442\u043E\u044F
      \u0432 \u0412\u0430\u0448\u0435\u0439 \u043E\u0447\u0435\u0440\u0435\u0434\u0438."
  - question: "\u0412\u044B\u0433\u043B\u044F\u0434\u0438\u0442\u0435 \u043D\u0435
      \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E. \u0412\u0430\u043C \u043D\u0443\u0436\u043D\u0430
      \u043F\u043E\u043C\u043E\u0449\u044C?"
    answer: "\u0422\u044B \u043B\u0443\u0447\u0448\u0435 \u0441\u0435\u0431\u0435
      \u043F\u043E\u043C\u043E\u0433\u0438 \u0438 \u0431\u044B\u0441\u0442\u0440\u0435\u0435
      \u0448\u0442\u0430\u043C\u043F\u044B \u0441\u0442\u0430\u0432\u044C. \u041C\u0430\u043B\u043E
      \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0432 \u043E\u0447\u0435\u0440\u0435\u0434\u0438
      \u043B\u044E\u0434\u0435\u0439 \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442\u0435
      \u0436\u0434\u0430\u0442\u044C, \u0442\u0430\u043A \u0435\u0449\u0435 \u0438
      \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C\u0438 \u0434\u0443\u0448\u0438\u0442\u0435.
      \u0414\u0430\u0432\u0430\u0439 \u0443\u0436\u0435 \u0436\u043C\u0438 \u043D\u0430
      \u0441\u0432\u043E\u0438 \u043A\u043D\u043E\u043F\u043A\u0438.\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0439
      \u043E\u0447\u0435\u0440\u0435\u0434\u0438 \u0442\u0440\u0438 \u0447\u0430\u0441\u0430"
  passingPhrase: "\u041D\u0430\u043A\u043E\u043D\u0435\u0446-\u0442\u043E"
  stayingPhrase: "\u0412\u043E\u043A\u0440\u0443\u0433 \u043E\u0434\u043D\u0438 \u0438\u0434\u0438\u043E\u0442\u044B"
