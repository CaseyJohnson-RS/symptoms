  m_Name: Angry woman
  m_EditorClassIdentifier: Assembly-CSharp::NPCData
  _name: "\u041B\u0438\u0434\u0438\u044F \u0421\u043D\u0435\u0436\u043E\u0432\u0430"
  male: 0
  infected: 0
  temperature: 36.8
  heartRate: 77
  arms: 0
  mouth: 0
  eyes: 0
  armpits: 0
  sprite: {fileID: 8931428327487941735, guid: c4148d33c407d29469ddb6f73028703f, type: 3}
  voiceClip: {fileID: 0}
  entryLines:
  - text: "\u041D\u0430\u0444\u0438\u0433\u0430 \u0431\u044B\u043B\u043E \u0434\u0435\u043B\u0430\u0442\u044C
      \u043F\u0443\u043D\u043A\u0442 \u0438 \u043D\u0430 \u0432\u044B\u0435\u0437\u0434\u0435
      \u0438 \u043D\u0430 \u0432\u044A\u0435\u0437\u0434\u0435?"
    delay: 1.5
  - text: "\u041D\u0440\u0430\u0432\u0438\u0442\u0441\u044F \u0438\u0437\u0434\u0435\u0432\u0430\u0442\u044C\u0441\u044F
      \u043D\u0430\u0434 \u043B\u044E\u0434\u044C\u043C\u0438!?"
    delay: 1
  dialog:
  - question: "\u0421 \u043A\u0430\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
      \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434?"
    answers:
    - text: "\u041D\u0435 \u0442\u0432\u043E\u0435 \u0434\u0435\u043B\u043E."
      delay: 1.5
    - text: "\u0425\u0432\u0430\u0442\u0438\u0442 \u043F\u043E\u043F\u0443\u0441\u0442\u0443
        \u0442\u0440\u0430\u0442\u0438\u0442\u044C \u043C\u043E\u0435 \u0432\u0440\u0435\u043C\u044F!"
      delay: 0.1
  - question: "\u0411\u043E\u043B\u0435\u043B\u0438 \u043B\u0438 \u0412\u044B \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0447\u0435\u043C-\u043B\u0438\u0431\u043E?"
    answers:
    - text: "\u0421\u043A\u0443\u043A\u043E\u0439 \u043E\u0442 \u043F\u0440\u043E\u0441\u0442\u043E\u0441\u0442\u043E\u044F
        \u0432 \u0412\u0430\u0448\u0435\u0439 \u043E\u0447\u0435\u0440\u0435\u0434\u0438."
      delay: 0.1
  - question: "\u0412\u044B\u0433\u043B\u044F\u0434\u0438\u0442\u0435 \u043D\u0435
      \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E. \u0412\u0430\u043C \u043D\u0443\u0436\u043D\u0430
      \u043F\u043E\u043C\u043E\u0449\u044C?"
    answers:
    - text: "\u0422\u044B \u043B\u0443\u0447\u0448\u0435 \u0441\u0435\u0431\u0435
        \u043F\u043E\u043C\u043E\u0433\u0438 \u0438 \u0431\u044B\u0441\u0442\u0440\u0435\u0435
        \u0448\u0442\u0430\u043C\u043F\u044B \u0441\u0442\u0430\u0432\u044C."
      delay: 1
    - text: "\u041C\u0430\u043B\u043E \u0442\u043E\u0433\u043E, \u0447\u0442\u043E
        \u0432 \u043E\u0447\u0435\u0440\u0435\u0434\u0438 \u043B\u044E\u0434\u0435\u0439
        \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442\u0435 \u0436\u0434\u0430\u0442\u044C,
        \u0442\u0430\u043A \u0435\u0449\u0435 \u0438 \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C\u0438
        \u0434\u0443\u0448\u0438\u0442\u0435."
      delay: 1.5
    - text: "\u0414\u0430\u0432\u0430\u0439 \u0443\u0436\u0435 \u0436\u043C\u0438
        \u043D\u0430 \u0441\u0432\u043E\u0438 \u043A\u043D\u043E\u043F\u043A\u0438,
        \u0411\u044E\u0440\u043E\u043A\u0440\u0430\u0442."
      delay: 0.1
  passingLines:
  - text: "\u041D\u0430\u043A\u043E\u043D\u0435\u0446-\u0442\u043E"
    delay: 0
  stayingLines:
  - text: "\u0412\u043E\u043A\u0440\u0443\u0433 \u043E\u0434\u043D\u0438 \u0438\u0434\u0438\u043E\u0442\u044B."
    delay: 1
  - text: "\u0427\u0442\u043E\u0431 \u0432\u0430\u0448\u0438 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B
      \u0432\u0435\u0447\u043D\u043E \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u043B\u0438
      \u0432 \u0430\u0434\u0443."
    delay: 1
