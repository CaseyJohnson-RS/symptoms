  _name: "\u0414\u043C\u0438\u0442\u0440\u0438\u0439 \u0421\u043C\u0435\u0448\u043D\u0438\u043A\u043E\u0432"
  male: 1
  infected: 0
  temperature: 35.8
  heartRate: 58
  arms: 0
  mouth: 0
  eyes: 0
  armpits: 0
  sprite: {fileID: -7929377079811121729, guid: 5ec854a619c7d894c8361bbb5fee1450, type: 3}
  voiceClip: {fileID: 8300000, guid: e3915aee755bdcb44a6e6b3b344f959e, type: 3}
  entryLines:
  - text: "\u041F\u0435\u0440\u0432\u044B\u0439 \u0437\u0430\u043A\u043E\u043D \u0437\u043E\u043C\u0431\u0438-\u0430\u043F\u043F\u043E\u043A\u0430\u043B\u0438\u043F\u0441\u0438\u0441\u0430:
      \u0431\u0443\u0434\u044C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
      \u0438 \u043A \u0442\u0435\u0431\u0435 \u043F\u043E\u0442\u044F\u043D\u0443\u0442\u0441\u044F."
    delay: 1.5
  - text: "\u041D\u0435 \u0441\u043C\u0435\u0448\u043D\u043E? \u0414\u0430\u0432\u0430\u0439
      \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u044E \u0435\u0449\u0435 \u0440\u0430\u0437."
    delay: 1.5
  - text: "\u041F\u0435\u0440\u0432\u044B\u0439 \u0437\u0430\u043A\u043E\u043D \u0437\u043E\u043C\u0431\u0438-\u0430\u043F\u043F\u043E\u043A\u0430\u043B\u0438\u043F\u0441\u0438\u0441\u0430:
      \u0431\u0443\u0434\u044C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
      \u0438 \u043A \u0442\u0435\u0431\u0435 \u043F\u043E\u0442\u044F\u043D\u0443\u0442\u0441\u044F."
    delay: 0
  dialog:
  - question: "\u0421 \u043A\u0430\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
      \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434?"
    answers:
    - text: "\u0414\u0430 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B
        \u043E\u043F\u044F\u0442\u044C \u0438\u0434\u0438\u043E\u0442\u0441\u043A\u0438\u0435.
        \u041F\u043E\u043D\u0430\u0431\u0438\u0440\u0430\u044E\u0442 \u0441 \u043E\u0431\u044A\u044F\u0432\u043B\u0435\u043D\u0438\u044F,
        \u043F\u043E\u0442\u043E\u043C \u043F\u0435\u0440\u0435\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0439
        \u0437\u0430 \u043D\u0438\u0445."
      delay: 0
  - question: "\u0411\u043E\u043B\u0435\u043B\u0438 \u043B\u0438 \u0412\u044B \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0447\u0435\u043C-\u043B\u0438\u0431\u043E?"
    answers:
    - text: "\u041D\u0435, \u044F \u043E\u0431\u044B\u0447\u043D\u043E \u0432\u0441\u0435
        \u043F\u0440\u043E\u0442\u0438\u0440\u0430\u044E \u043F\u0435\u0440\u0435\u0434
        \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C.
        \u0414\u0430 \u0438 \u0447\u0443\u0436\u0438\u043C\u0438 \u0432\u0435\u0449\u0430\u043C\u0438
        \u043D\u0435 \u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0441\u044C."
      delay: 0.1
  - question: "\u0412\u0430\u043C \u043D\u0435 \u0445\u043E\u043B\u043E\u0434\u043D\u043E?"
    answers:
    - text: "\u0415\u0441\u0442\u044C \u0441\u043B\u0435\u0433\u043A\u0430. \u0417\u0430\u0442\u043E
        \u0440\u0443\u043A\u0430\u0432\u043E\u0432 \u043D\u0435\u0442 \u0438 \u0432\u0435\u043D\u044B
        \u0432\u0438\u0434\u043D\u043E. "
      delay: 0
  passingLines:
  - text: "\u041D\u0435 \u0441\u043A\u0443\u0447\u0430\u0439 \u0442\u0443\u0442 \u0431\u0435\u0437
      \u043C\u0435\u043D\u044F."
    delay: 1
  stayingLines:
  - text: "\u041B\u0430\u0434\u043D\u043E, \u043F\u043E\u0439\u0434\u0443 \u043D\u0430
      \u0443\u043B\u0438\u0446\u0435 \u043F\u043E\u0433\u0440\u0435\u044E\u0441\u044C."
    delay: 1
