  m_EditorClassIdentifier: Assembly-CSharp::NPCData
  _name: "\u041D\u0438\u043A\u0438\u0442\u0430 \u0417\u043E\u043B\u043E\u0442\u043E\u0432"
  infected: 1
  temperature: 25
  heartRate: 160
  arms: 1
  mouth: 1
  eyes: 0
  armpits: 1
  sprite: {fileID: -4809020055532083392, guid: f2589c4c60694714fbb0267eaaf5449a, type: 3}
  voiceClip: {fileID: 8300000, guid: e3915aee755bdcb44a6e6b3b344f959e, type: 3}
  dialog:
  - question: "\u0421 \u043A\u0430\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
      \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434?"
    answer: "\u0414\u0430\u0436\u0435 \u043D\u0435 \u0437\u043D\u0430\u044E, \u0430
      \u043A\u0430\u043A \u043E\u0431\u044B\u0447\u043D\u043E \u043D\u0430 \u044D\u0442\u043E\u0442
      \u0432\u043E\u043F\u0440\u043E\u0441 \u043E\u0442\u0432\u0435\u0447\u0430\u044E\u0442?"
  - question: "\u0411\u043E\u043B\u0435\u043B\u0438 \u043B\u0438 \u0412\u044B \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0447\u0435\u043C-\u043B\u0438\u0431\u043E?"
    answer: "\u0415\u0441\u0442\u044C \u0447\u0443\u0432\u0441\u0442\u0432\u043E
      \u043D\u0435\u0434\u043E\u043C\u0430\u0433\u0430\u043D\u0438\u044F. \u042D\u0442\u043E
      \u043A\u0440\u0438\u0442\u0438\u0447\u043D\u043E?"
  - question: "\u0412\u0430\u043C \u043D\u0435 \u0436\u0430\u0440\u043A\u043E \u0432
      \u043A\u0443\u0440\u0442\u043A\u0435?"
    answer: "\u0423 \u0432\u0430\u0441 \u0442\u0443\u0442 \u043F\u0440\u043E\u0445\u043B\u0430\u0434\u043D\u043E,
      \u0445\u043E\u0442\u044F \u043D\u0435 \u0442\u0430\u043A \u0445\u043E\u043B\u043E\u0434\u043D\u043E
      \u043A\u0430\u043A \u043D\u0430 \u0443\u043B\u0438\u0446\u0435, \u043A\u043E\u043D\u0435\u0447\u043D\u043E.
      \u042F \u0431\u044B \u0438 \u043F\u0435\u0440\u0447\u0430\u0442\u043A\u0438
      \u043D\u0430\u0434\u0435\u043B. \u0423\u0436\u0435 \u0432\u0441\u0435 \u043F\u0430\u043B\u044C\u0446\u044B
      \u043E\u0442\u043C\u043E\u0440\u043E\u0437\u0438\u043B"
  passingPhrase: "\u041D\u0430\u0434\u043E \u0431\u044B \u043F\u0440\u0438\u043A\u0443\u043F\u0438\u0442\u044C
    \u043F\u0435\u0440\u0447\u0430\u0442\u043A\u0438"
  stayingPhrase: "\u041C\u043E\u0436\u043D\u043E \u044F \u0445\u043E\u0442\u044F
    \u0431\u044B \u0443 \u0432\u0430\u0441 \u043D\u0435\u043C\u043D\u043E\u0433\u043E
    \u043F\u043E\u0433\u0440\u0435\u044E\u0441\u044C?"
