  dialog:
  - question: "\u0421 \u043A\u0430\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
      \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434?"
    answer: "\u041D\u0430 \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
      \u0432 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u044E \u043F\u043E \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u044E
      \u0432\u0442\u043E\u0440\u044B\u0445 \u043F\u043E\u043B\u0434\u043D\u0438\u043A\u043E\u0432."
  - question: "\u0411\u043E\u043B\u0435\u043B\u0438 \u043B\u0438 \u0412\u044B \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0447\u0435\u043C-\u043B\u0438\u0431\u043E?"
    answer: "\u041D\u0435\u0442."
  - question: "\u0412\u044B \u0437\u0430\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0439?"
    answer: "\u041D\u0435\u0442."
  passingPhrase: "\u042D\u0442\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u043E"
  stayingPhrase: "\u041D\u0443 \u043B\u0430\u0434\u043D\u043E"
