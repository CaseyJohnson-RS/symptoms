  m_text: "\u041D\u0438\u0433\u0440\u0438\u0434\u0438\u0435\u043D\u0442\u044B \u0434\u043B\u044F
    \u0442\u0438\u0440\u0430\u043C\u0438\u0441\u0441\u0443: \u0414\u043B\u044F \u043F\u0440\u0438\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u044F
    \u043F\u043E\u043B\u0443\u043A\u0438\u043B\u043E\u0433\u0440\u0430\u043C\u043C\u043E\u0432\u043E\u0433\u043E
    \u0442\u043E\u0440\u0442\u0430 \u0432\u0430\u043C \u043F\u043E\u043D\u0430\u0434\u043E\u0431\u0438\u0442\u0441\u044F
    \u0442\u0440\u0438 \u044F\u0439\u0446\u0430, \u0441\u044B\u0440 \u043C\u0430\u0441\u043A\u0430\u0440\u043F\u043E\u043D\u0435
    300 \u0433\u0440\u0430\u043C\u043C, \u0441\u0430\u0445\u0430\u0440\u043D\u0430\u044F
    \u043F\u0443\u0434\u0440\u0430 \u0433\u0440\u0430\u043C\u043C 10, \u043A\u043E\u0444\u0435,
    \u0441\u043E\u043B\u044C, \u0441\u0430\u0445\u0430\u0440, \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u0435\u0447\u0435\u043D\u044C\u044F \u0438 \u043F\u0430\u0440\u0443 \u043A\u043E\u043D\u0442\u0435\u0439\u043D\u0435\u0440\u043E\u0432."
